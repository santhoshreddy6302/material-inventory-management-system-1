# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database configuration
DATABASE_URL="postgresql://username:password@localhost:5432/material_inventory?schema=public"

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=material_inventory

# JWT
JWT_SECRET=mims_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=mims_super_secret_refresh_jwt_key_change_in_production_min_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# Image storage (Cloudinary configuration)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads
